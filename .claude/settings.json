{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "python3 -c \"import json,sys,datetime,os; d=json.load(sys.stdin); cmd=d.get('tool_input',{}).get('command',''); os.makedirs('.claude',exist_ok=True); open('.claude/hook-log.txt','a').write(datetime.datetime.now().isoformat()+'\\tPreToolUse\\t'+cmd[:500]+'\\n')\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash .claude/hooks/structure-review.sh",
            "timeout": 180,
            "statusMessage": "Running advisory structure review..."
          }
        ]
      }
    ]
  }
}
